#!/usr/bin/env python3
import sys
import urllib.request
import urllib.error

def extract_url(args):
    """
    Robustly extracts the URL regardless of how Vex formats or splits it.
    """
    # 1. Look for a standard url="..." or url=...
    for arg in args:
        if arg.startswith("url="):
            return arg.split("=", 1)[1].strip('"')
            
    # 2. Look for an loose assignment if spaces split it (e.g., ['url', '=', 'http...'])
    full_str = " ".join(args)
    if "url=" in full_str:
        try:
            target = full_str.split("url=")[1].strip()
            if target.startswith('"'):
                return target.split('"')[1]
            return target.split(" ")[0]
        except:
            pass

    # 3. Ultimate Fallback: Just look for any argument that looks like a web address
    for arg in args:
        clean_arg = arg.strip('"')
        if clean_arg.startswith(("http://", "https://", "www.")) or "." in clean_arg:
            if clean_arg != "http": # Don't accidentally grab the opcode
                return clean_arg
                
    return ""

def main():
    args = sys.argv[1:]
    
    if not args:
        print("Error: No opcode provided.", file=sys.stderr)
        sys.exit(1)
        
    opcode = args[0]
    
    if opcode == "http":
        # Extract the URL parameter first
        url = extract_url(args)
        
        # If it still couldn't find it, print exactly what Vex sent so you can debug it
        if not url:
            print(f"Error: Missing 'url' parameter. Vex sent these arguments: {args}", file=sys.stderr)
            sys.exit(1)
            
        # Ensure the URL has a proper scheme
        if not url.startswith(("http://", "https://")):
            url = "https://" + url

        try:
            # Set a standard User-Agent header to behave like cURL
            req = urllib.request.Request(
                url, 
                headers={'User-Agent': 'Mozilla/5.0 (VexLibraryFetch/1.0)'}
            )
            with urllib.request.urlopen(req, timeout=10) as response:
                output = response.read().decode('utf-8', errors='replace')
                # Print the exact output back to Vex
                print(output, end="")
                sys.exit(0)
                
        except urllib.error.URLError as e:
            print(f"Network Error: {e.reason}", file=sys.stderr)
            sys.exit(1)
        except Exception as e:
            print(f"Error: {str(e)}", file=sys.stderr)
            sys.exit(1)
            
    else:
        print(f"Error: Unknown opcode '{opcode}'", file=sys.stderr)
        sys.exit(1)

if __name__ == "__main__":
    main()
