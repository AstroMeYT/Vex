#!/usr/bin/env python3
import sys
import urllib.request
import urllib.error
import json

def extract_arg(args, key):
    """
    Robustly extracts argument values regardless of how Vex formats or splits them.
    """
    for arg in args:
        if arg.startswith(f"{key}="):
            return arg.split("=", 1)[1].strip('"')
            
    full_str = " ".join(args)
    if f"{key}=" in full_str:
        try:
            target = full_str.split(f"{key}=")[1].strip()
            if target.startswith('"'):
                return target.split('"')[1]
            return target.split(" ")[0]
        except:
            pass

    # Ultimate Fallback for the URL itself
    if key == "url":
        for arg in args:
            clean_arg = arg.strip('"')
            if clean_arg.startswith(("http://", "https://", "www.")) or "." in clean_arg:
                # Make sure we don't accidentally grab an opcode name
                if clean_arg not in ["get", "post", "put", "patch", "delete"]:
                    return clean_arg
    return ""

def make_request(url, method, data_str=None, headers_str=None):
    # Ensure the URL has a proper scheme
    if not url.startswith(("http://", "https://")):
        url = "https://" + url

    # Parse payload data if provided
    data_bytes = None
    if data_str:
        # If it's valid JSON, keep it as text bytes, otherwise encode raw string
        try:
            json.loads(data_str)
            data_bytes = data_str.encode('utf-8')
        except ValueError:
            data_bytes = data_str.encode('utf-8')

    # Base headers to mimic a native browser/cURL client
    headers = {'User-Agent': 'Mozilla/5.0 (VexLibraryFetch/1.0)'}
    
    # Parse custom headers if passed (expects a JSON string like headers='{"Content-Type":"application/json"}')
    if headers_str:
        try:
            custom_headers = json.loads(headers_str)
            if isinstance(custom_headers, dict):
                headers.update(custom_headers)
        except ValueError:
            pass

    # If data is provided but no Content-Type was explicitly set, default to JSON
    if data_bytes and 'Content-Type' not in headers:
        headers['Content-Type'] = 'application/json'

    try:
        req = urllib.request.Request(url, data=data_bytes, headers=headers, method=method.upper())
        with urllib.request.urlopen(req, timeout=10) as response:
            output = response.read().decode('utf-8', errors='replace')
            # Print the output straight to stdout so Vex captures it perfectly
            print(output, end="")
            sys.exit(0)
            
    except urllib.error.HTTPError as e:
        # Return the raw error body if the server responded with an error code (4xx/5xx)
        try:
            error_output = e.read().decode('utf-8', errors='replace')
            print(error_output, end="")
        except:
            print(f"HTTP Error {e.code}: {e.reason}", file=sys.stderr)
        sys.exit(0) # Exit cleanly so Vex receives the payload response state
    except urllib.error.URLError as e:
        print(f"Network Error: {e.reason}", file=sys.stderr)
        sys.exit(1)
    except Exception as e:
        print(f"Error: {str(e)}", file=sys.stderr)
        sys.exit(1)

def main():
    args = sys.argv[1:]
    if not args:
        print("Error: No method opcode provided.", file=sys.stderr)
        sys.exit(1)
        
    opcode = args[0].lower()
    
    # Map valid Vex method opcodes
    if opcode in ["get", "post", "put", "patch", "delete"]:
        url = extract_arg(args, "url")
        data = extract_arg(args, "data")
        headers = extract_arg(args, "headers")
        
        if not url:
            print(f"Error: Missing required 'url' parameter.", file=sys.stderr)
            sys.exit(1)
            
        make_request(url, method=opcode, data_str=data, headers_str=headers)
    else:
        print(f"Error: Unknown HTTP method opcode '{opcode}'", file=sys.stderr)
        sys.exit(1)

if __name__ == "__main__":
    main()
