#!/usr/bin/env python3
import sys
import urllib.request
import urllib.error

def extract_arg(args, key):
    """
    Safely extracts the value for a given key (e.g., url="...")
    even if Vex splits the argument by spaces.
    """
    for arg in args:
        if arg.startswith(f"{key}="):
            return arg.split("=", 1)[1].strip('"')
            
    # Fallback: re-assemble the string if spaces split the URL
    full_str = " ".join(args)
    if f"{key}=" in full_str:
        try:
            target = full_str.split(f"{key}=")[1]
            if target.startswith('"'):
                return target.split('"')[1]
            return target.split(" ")[0]
        except:
            pass
    return ""

def main():
    # Vex passes arguments separated by spaces: [path, opcode, variable1=val, ...]
    # Example: ./fetch http url="https://example.com"
    args = sys.argv[1:]
    
    if not args:
        print("Error: No opcode provided.", file=sys.stderr)
        sys.exit(1)
        
    opcode = args[0]
    
    if opcode == "http":
        url = extract_arg(args, "url")
        
        if not url:
            print("Error: Missing 'url' parameter.", file=sys.stderr)
            sys.exit(1)
            
        # Ensure the URL has a proper scheme
        if not url.startswith(("http://", "https://")):
            url = "https://" + url

        try:
            # Set a standard User-Agent header to behave like cURL/browsers
            req = urllib.request.Request(
                url, 
                headers={'User-Agent': 'Mozilla/5.0 (VexLibraryFetch/1.0)'}
            )
            with urllib.request.urlopen(req, timeout=10) as response:
                # Read the raw data and decode it to text
                output = response.read().decode('utf-8', errors='replace')
                # Print the exact output back to Vex to be captured by the globalvar
                print(output, end="")
                sys.exit(0)
                
        except urllib.error.URLError as e:
            print(f"Network Error: {e.reason}", file=sys.stderr)
            sys.exit(1)
        except Exception as e:
            print(f"Error: {str(e)}", file=sys.stderr)
            sys.exit(1)
            
    else:
        print(f"Error: Unknown opcode '{opcode}'", file=sys.stderr)
        sys.exit(1)

if __name__ == "__main__":
    main()
