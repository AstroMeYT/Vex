#!/usr/bin/env python3
import sys
import os

def extract_arg(args, key):
    """Safely extracts parameter values regardless of space splitting."""
    for arg in args:
        if arg.startswith(f"{key}="):
            return arg.split("=", 1)[1].strip('"')
            
    full_str = " ".join(args)
    if f"{key}=" in full_str:
        try:
            target = full_str.split(f"{key}=")[1].strip()
            if target.startswith('"'):
                return target.split('"')[1]
            return target.split(" ")[0]
        except:
            pass
    return ""

def main():
    args = sys.argv[1:]
    
    if not args:
        sys.exit(1)
        
    opcode = args[0]
    
    # Feature 1: Clear the terminal screen
    if opcode == "clear":
        # Returns the ANSI clear codes so Vex's print engine can process the clear action
        print("\033[2J\033[H", end="")
        sys.exit(0)
        
    # Feature 2: Get terminal size
    elif opcode == "size":
        try:
            columns, lines = os.get_terminal_size()
            print(f"{columns}x{lines}")
        except:
            print("80x24")
        sys.exit(0)
        
    # Feature 3: Move cursor coordinates
    elif opcode == "move":
        x = extract_arg(args, "x")
        y = extract_arg(args, "y")
        if x and y:
            # Returns the raw ANSI coordinate jump sequence to the capturing variable
            print(f"\033[{y};{x}H", end="")
        sys.exit(0)

    # Feature 4: Write text with a specific style/color
    elif opcode == "write":
        text = extract_arg(args, "text")
        color = extract_arg(args, "color").lower()
        
        # Fallback if Vex strips 'text=' and leaves loose words
        if not text and len(args) > 1:
            text_parts = [a for a in args[1:] if not a.startswith("color=")]
            text = " ".join(text_parts).strip('"')

        # Translate string-escaped characters back to native formatting literals
        if text:
            text = text.replace(r"\n", "\n").replace(r"\t", "\t")

        colors = {
            "red": "\033[31m",
            "green": "\033[32m",
            "yellow": "\033[33m",
            "blue": "\033[34m",
            "magenta": "\033[35m",
            "cyan": "\033[36m",
            "bold": "\033[1m"
        }
        
        start_code = colors.get(color, "")
        end_code = "\033[0m" if start_code else ""
        
        # Print directly to stdout. Vex will intercept this string 
        # and cleanly feed it to your assigned globalvar variable.
        print(f"{start_code}{text}{end_code}", end="")
        sys.exit(0)
        
    else:
        sys.exit(1)

if __name__ == "__main__":
    main()
