#!/usr/bin/env python3
import sys
import os

def extract_arg(args, key):
    """Safely extracts parameter values regardless of space splitting."""
    for arg in args:
        if arg.startswith(f"{key}="):
            return arg.split("=", 1)[1].strip('"')
            
    full_str = " ".join(args)
    if f"{key}=" in full_str:
        try:
            target = full_str.split(f"{key}=")[1].strip()
            if target.startswith('"'):
                return target.split('"')[1]
            return target.split(" ")[0]
        except:
            pass
    return ""

def main():
    args = sys.argv[1:]
    
    if not args:
        print("Error: No opcode provided.", file=sys.stderr)
        sys.exit(1)
        
    opcode = args[0]
    
    # Feature 1: Clear the terminal screen
    # Vex: screen.clear() -> Under the hood: ./screen clear
    if opcode == "clear":
        # Works across Windows (nt) and Unix/Linux/macOS (posix)
        os.system('cls' if os.name == 'nt' else 'clear')
        sys.exit(0)
        
    # Feature 2: Get terminal size (returns width and height)
    # Vex: globalvar size = screen.size() -> Under the hood: ./screen size
    elif opcode == "size":
        try:
            columns, lines = os.get_terminal_size()
            print(f"{columns}x{lines}")
        except:
            print("80x24") # Standard fallback
        sys.exit(0)
        
    # Feature 3: Move cursor to specific X/Y terminal coordinates
    # Vex: screen.move(x=10, y=5) -> Under the hood: ./screen move x=10 y=5
    elif opcode == "move":
        x = extract_arg(args, "x")
        y = extract_arg(args, "y")
        if x and y:
            # ANSI escape code to position cursor: \033[Line;ColumnH
            print(f"\033[{y};{x}H", end="")
        sys.exit(0)

    # Feature 4: Print text with a specific style/color
    # Vex: screen.print(text="Hello", color="red") -> Under the hood: ./screen print text="Hello" color="red"
    elif opcode == "print":
        text = extract_arg(args, "text")
        color = extract_arg(args, "color").lower()
        
        colors = {
            "red": "\033[31m",
            "green": "\033[32m",
            "yellow": "\033[33m",
            "blue": "\033[34m",
            "magenta": "\033[35m",
            "cyan": "\033[36m",
            "bold": "\033[1m"
        }
        
        start_code = colors.get(color, "")
        end_code = "\033[0m" if start_code else ""
        
        print(f"{start_code}{text}{end_code}")
        sys.exit(0)
        
    else:
        print(f"Error: Unknown opcode '{opcode}'", file=sys.stderr)
        sys.exit(1)

if __name__ == "__main__":
    main()
