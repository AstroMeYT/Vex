#!/usr/bin/env python3
import sys
import os
import socket
import threading
import json
import queue
import tkinter as tk
from tkinter import ttk

HOST = '127.0.0.1'
PORT = 65432

# Thread-safe queue to pass commands safely to the Tkinter main loop
gui_queue = queue.Queue()

def start_gui_daemon():
    """Starts the persistent Tkinter window process decoupled from the terminal."""
    root = tk.Tk()
    root.title("Vex Window Daemon")
    root.geometry("400x300")
    
    widgets = {}
    
    def process_queue():
        """Polls the queue for updates and forces Tkinter to render them immediately."""
        try:
            while True:
                cmd = gui_queue.get_nowait()
                action = cmd.get("action")
                w_id = cmd.get("id")
                
                if action == "title":
                    root.title(cmd["text"])
                elif action == "geometry":
                    root.geometry(cmd["size"])
                elif action == "create_label":
                    lbl = ttk.Label(root, text=cmd["text"])
                    lbl.pack(pady=5)
                    widgets[w_id] = lbl
                elif action == "create_button":
                    btn = ttk.Button(root, text=cmd["text"])
                    btn.pack(pady=5)
                    widgets[w_id] = btn
                elif action == "update_text":
                    if w_id in widgets:
                        widgets[w_id].config(text=cmd["text"])
                elif action == "close":
                    root.destroy()
                    return
                
                # Force Tkinter to refresh the screen layout and text pixels immediately
                root.update_idletasks()
                gui_queue.task_done()
        except queue.Empty:
            pass
        
        # Check the queue again every 50 milliseconds
        root.after(50, process_queue)

    def handle_client(conn):
        with conn:
            try:
                data = conn.recv(4096).decode('utf-8')
                if not data:
                    return
                cmd = json.loads(data)
                
                # Safely drop the command into the thread-safe queue
                gui_queue.put(cmd)
                conn.sendall(b"OK")
            except Exception as e:
                conn.sendall(f"ERROR: {str(e)}".encode('utf-8'))

    def socket_server():
        with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
            s.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
            s.bind((HOST, PORT))
            s.listen()
            while True:
                try:
                    conn, _ = s.accept()
                    threading.Thread(target=handle_client, args=(conn,), daemon=True).start()
                except:
                    break

    # Start the network listener thread
    threading.Thread(target=socket_server, daemon=True).start()
    
    # Initialize the queue polling loop on the Tkinter main loop thread
    root.after(50, process_queue)
    root.mainloop()

def send_command(command_dict):
    try:
        with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
            s.connect((HOST, PORT))
            s.sendall(json.dumps(command_dict).encode('utf-8'))
            return s.recv(1024).decode('utf-8')
    except ConnectionRefusedError:
        return "DAEMON_NOT_RUNNING"

def extract_arg(args, key):
    for arg in args:
        if arg.startswith(f"{key}="):
            return arg.split("=", 1)[1].strip('"')
    full_str = " ".join(args)
    if f"{key}=" in full_str:
        try:
            target = full_str.split(f"{key}=")[1]
            if target.startswith('"'):
                return target.split('"')[1]
            return target.split(" ")[0]
        except:
            pass
    return ""

def main():
    args = sys.argv[1:]
    if not args:
        sys.exit(1)
        
    opcode = args[0]
    
    if opcode == "init":
        status = send_command({"action": "ping"})
        if status == "DAEMON_NOT_RUNNING":
            try:
                pid = os.fork()
                if pid > 0:
                    print("SUCCESS")
                    sys.exit(0)
            except OSError as e:
                print(f"Fork #1 failed: {e}", file=sys.stderr)
                sys.exit(1)

            os.chdir("/")
            os.setsid()
            os.umask(0)

            try:
                pid = os.fork()
                if pid > 0:
                    sys.exit(0)
            except OSError as e:
                print(f"Fork #2 failed: {e}", file=sys.stderr)
                sys.exit(1)

            sys.stdout.flush()
            sys.stderr.flush()
            si = open(os.devnull, 'r')
            so = open(os.devnull, 'a+')
            se = open(os.devnull, 'a+')
            
            os.dup2(si.fileno(), sys.stdin.fileno())
            os.dup2(so.fileno(), sys.stdout.fileno())
            os.dup2(se.fileno(), sys.stderr.fileno())

            start_gui_daemon()
            sys.exit(0)
        else:
            print("ALREADY_RUNNING")
            
    elif opcode == "title":
        text = extract_arg(args, "text")
        print(send_command({"action": "title", "text": text}))

    elif opcode == "geometry":
        size = extract_arg(args, "size")
        print(send_command({"action": "geometry", "size": size}))

    elif opcode == "label":
        w_id = extract_arg(args, "id")
        text = extract_arg(args, "text")
        print(send_command({"action": "create_label", "id": w_id, "text": text}))

    elif opcode == "button":
        w_id = extract_arg(args, "id")
        text = extract_arg(args, "text")
        print(send_command({"action": "create_button", "id": w_id, "text": text}))

    elif opcode == "update":
        w_id = extract_arg(args, "id")
        text = extract_arg(args, "text")
        print(send_command({"action": "update_text", "id": w_id, "text": text}))

    elif opcode == "close":
        print(send_command({"action": "close"}))

if __name__ == "__main__":
    main()
